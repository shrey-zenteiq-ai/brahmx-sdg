# BrahmX SDG — Vertex AI Pipeline Environment Variables
# Copy to pipelines/vertex/.env and fill in your values.
# Never commit the real .env file.

# ── GCP Project ───────────────────────────────────────────────────────────────
PROJECT_ID=your-project-id
LOCATION=us-central1

# ── Service Account ───────────────────────────────────────────────────────────
SA_NAME=brahmx-vertex-sa
SA_EMAIL=brahmx-vertex-sa@your-project-id.iam.gserviceaccount.com

# ── GCS Bucket (pipeline root + all artifacts) ────────────────────────────────
# This bucket will hold: pipeline root, specs, KB chunks, gold bundles, corpus.
PIPELINE_BUCKET=brahmx-sdg-artifacts

# ── Artifact Registry ─────────────────────────────────────────────────────────
ARTIFACT_REPO=brahmx
IMAGE_NAME=sdg

# ── Secret Manager ────────────────────────────────────────────────────────────
# Name of the Secret Manager secret that holds the OpenAI API key.
# Add the key with:
#   printf 'sk-...' | gcloud secrets versions add openai-api-key --data-file=-
OPENAI_SECRET_ID=openai-api-key

# ── Set by build_and_push.sh — do not edit manually ──────────────────────────
# BRAHMX_IMAGE_URI is written to pipelines/vertex/.image_uri.env after a build.
# Source that file or set this manually:
# BRAHMX_IMAGE_URI=us-central1-docker.pkg.dev/your-project-id/brahmx/sdg:latest
