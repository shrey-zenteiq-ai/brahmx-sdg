# BrahmX SDG — Environment Variables
# Copy to .env and fill in values:
#   cp .env.example .env
#   then edit .env

# ── Required ──────────────────────────────────────────────────────────────────

# OpenAI API key — used as inference placeholder until TPU vLLM pods are ready.
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Optional ──────────────────────────────────────────────────────────────────

# Environment tag (dev / staging / prod)
BRAHMX_ENV=dev

# GCS bucket for production artifact storage
# Leave empty to use local filesystem (default in dev)
BRAHMX_GCS_BUCKET=

# GCS path prefix inside the bucket
BRAHMX_GCS_PREFIX=brahmx-sdg

# Log level (DEBUG / INFO / WARNING / ERROR)
BRAHMX_LOG_LEVEL=INFO
